{
  "type": "object",
  "additionalProperties": true,
  "required": [
    "sample_id",
    "source_dataset",
    "ui_phase",
    "interaction_demand",
    "modes",
    "dominant_mode",
    "threat_level",
    "action_window",
    "urgency_level",
    "recommended_policy_set",
    "prior_attack",
    "prior_dodge",
    "confidence",
    "ttl_ms",
    "rationale_short",
    "should_use_for_training",
    "quality_flags"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "source_dataset": {
      "type": "string"
    },
    "ui_phase": {
      "enum": [
        "gameplay",
        "menu",
        "dialog",
        "result",
        "loading",
        "unknown"
      ]
    },
    "interaction_demand": {
      "type": "object",
      "required": [
        "action_intensity",
        "temporal_urgency",
        "information_priority",
        "occlusion_risk",
        "control_continuity",
        "ui_skill_proxy"
      ],
      "properties": {
        "action_intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "temporal_urgency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "information_priority": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "occlusion_risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "control_continuity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ui_skill_proxy": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "modes": {
      "type": "object",
      "required": [
        "action_first",
        "cognition_first",
        "guidance_procedure",
        "learning_review"
      ],
      "properties": {
        "action_first": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "cognition_first": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "guidance_procedure": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "learning_review": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "dominant_mode": {
      "enum": [
        "action_first",
        "cognition_first",
        "guidance_procedure",
        "learning_review",
        "unknown"
      ]
    },
    "threat_level": {
      "enum": [
        "none",
        "warning",
        "active",
        "critical",
        "unknown"
      ]
    },
    "action_window": {
      "enum": [
        "engage",
        "avoid",
        "wait",
        "explore",
        "unknown"
      ]
    },
    "urgency_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "recommended_policy_set": {
      "type": "array",
      "items": {
        "enum": [
          "visibility",
          "emphasis",
          "density",
          "position_constraint",
          "interaction_error_tolerance",
          "feedback_intensity"
        ]
      }
    },
    "prior_attack": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "prior_dodge": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ttl_ms": {
      "type": "integer",
      "minimum": 0
    },
    "rationale_short": {
      "type": "string"
    },
    "should_use_for_training": {
      "type": "boolean"
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}